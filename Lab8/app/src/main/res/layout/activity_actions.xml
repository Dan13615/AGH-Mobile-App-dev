<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white"
    tools:context=".ActionsActivity">

    <Button
        android:id="@+id/write_to_log_cat_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="@string/write_to_logcat"
        android:backgroundTint="#6A0DAD"
        android:textSize="16sp" />

    <Button
        android:id="@+id/show_toast_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/show_toast"
        android:backgroundTint="#6A0DAD"
        android:textSize="16sp" />

    <Button
        android:id="@+id/write_to_edit_text_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/write_to_edit_text"
        android:backgroundTint="#6A0DAD"
        android:textSize="16sp" />

    <Button
        android:id="@+id/back_to_first_fragment_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/back_to_first_fragment"
        android:backgroundTint="#6A0DAD"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/output_edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="Output will appear here..."
        android:textSize="16sp" />

</LinearLayout>